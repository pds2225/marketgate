# VALUE-UP AI 환경 변수 설정 예시
# 이 파일을 .env로 복사하고 실제 값을 입력하세요

# 데이터 소스 설정
USE_REAL_DATA=false  # true로 설정하면 실제 API 호출

# UN Comtrade API
# 발급: https://comtradeplus.un.org/
UN_COMTRADE_API_KEY=

# 캐시 설정
ENABLE_CACHE=true
CACHE_EXPIRY_HOURS=24

# API 서버 설정
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# 로그 레벨
LOG_LEVEL=INFO
